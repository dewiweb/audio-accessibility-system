# =============================================
# Audio Accessibility System — Configuration
# =============================================
# Copiez ce fichier en .env et adaptez les valeurs

# --- Environnement ---
# Mettre "production" pour activer les vérifications de sécurité strictes
# (mot de passe par défaut interdit, SESSION_SECRET min 32 chars obligatoire)
NODE_ENV=production

# --- Serveur ---
PORT=8080
HOST=0.0.0.0
HTTPS_PORT=8443

# --- TLS ---
# CN utilisé pour le certificat auto-signé (IP ou nom d'hôte du serveur)
TLS_CN=192.168.100.251
# Pour utiliser vos propres certificats (Let's Encrypt, etc.) :
# CERT_PATH=/app/certs/server.crt
# KEY_PATH=/app/certs/server.key

# --- Double interface réseau (production) ---
# Laisser commenté = mode single-interface (dev / fallback).
# ADMIN_HOST  : IP interface réseau régie  (admin + AES67 + WebSocket)
# ADMIN_PORT  : port HTTPS admin (défaut = HTTPS_PORT)
# PUBLIC_HOST : IP interface WiFi public   (/, /hls uniquement, /admin bloqué)
# PUBLIC_PORT : port HTTPS public (défaut = HTTPS_PORT)
# PUBLIC_LISTENER_URL : URL communiquée aux spectateurs (QR code)
#ADMIN_HOST=192.168.100.251
#ADMIN_PORT=8443
#PUBLIC_HOST=10.0.0.1
#PUBLIC_PORT=8443
#PUBLIC_LISTENER_URL=https://10.0.0.1:8443

# --- Sécurité (OBLIGATOIRE: changer ces valeurs !) ---
# Mot de passe administrateur — min 12 caractères recommandés (ANSSI)
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD_MIN12
# Secret de session — min 32 caractères, générer avec : openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_32_CHARS_MIN_openssl_rand_hex_32
# Nombre de rounds bcrypt (12 = ~250ms/vérification, bon équilibre sécurité/perf)
BCRYPT_ROUNDS=12

# --- Rate limiting authentification (anti brute-force, ANSSI RGS) ---
# Fenêtre de temps en ms (défaut: 15 minutes)
RATE_LIMIT_AUTH_WINDOW_MS=900000
# Nombre max de tentatives dans la fenêtre (défaut: 10)
RATE_LIMIT_AUTH_MAX=10

# --- CORS ---
# Origines autorisées (séparées par des virgules), ex: https://192.168.100.251:8443
# Laisser vide pour bloquer tout cross-origin (recommandé en production)
ALLOWED_ORIGINS=

# --- URL publique (IP du serveur Docker sur votre réseau WiFi) ---
# C'est l'URL que verra le QR code affiché en salle
PUBLIC_URL=https://192.168.100.251:8443

# --- Audio HLS ---
HLS_SEGMENT_DURATION=1
HLS_LIST_SIZE=3
AUDIO_SAMPLE_RATE=48000
AUDIO_BITRATE=128k

# --- AES67 / RTP multicast ---
# Tampon jitter réseau en ms — trade-off latence vs stabilité :
#   20ms  : latence minimale, LAN filaire dédié uniquement (risque de glitches sur WiFi)
#   50ms  : bon équilibre LAN/WiFi dédié salle
#   200ms : conservateur, réseau partagé ou WiFi grand public
RTP_BUFFER_MS=50
# Interface réseau pour rejoindre les groupes multicast
# Laisser vide pour auto-détection, ou spécifier l'IP de l'interface réseau
# vers votre réseau AES67 (ex: 192.168.1.100 ou eth0)
MULTICAST_INTERFACE=
