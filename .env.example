# =============================================
# Audio Accessibility System — Configuration
# =============================================
# Copiez ce fichier en .env et adaptez les valeurs

# --- Serveur ---
PORT=8080
HOST=0.0.0.0

# --- Sécurité (OBLIGATOIRE: changer ces valeurs !) ---
ADMIN_PASSWORD=changeme
SESSION_SECRET=changeme-secret-key-min-32-chars

# --- URL publique (IP du serveur Docker sur votre réseau WiFi) ---
# C'est l'URL que verra le QR code affiché en salle
PUBLIC_URL=http://192.168.100.251:8080

# --- Audio HLS ---
HLS_SEGMENT_DURATION=1
HLS_LIST_SIZE=3
AUDIO_SAMPLE_RATE=48000
AUDIO_BITRATE=128k

# --- AES67 / RTP multicast ---
# Tampon jitter réseau en ms (augmenter à 400-500 si vous avez des coupures)
RTP_BUFFER_MS=200
# Interface réseau pour rejoindre les groupes multicast
# Laisser vide pour auto-détection, ou spécifier l'IP de l'interface réseau
# vers votre réseau AES67 (ex: 192.168.1.100 ou eth0)
MULTICAST_INTERFACE=
