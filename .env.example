# =============================================
# Audio Accessibility System — Configuration
# =============================================
# Copiez ce fichier en .env et adaptez les valeurs

# --- Serveur ---
PORT=8080
HOST=0.0.0.0

# --- HTTPS intégré (cert auto-signé généré au démarrage) ---
# TLS_CN : nom/IP inscrit dans le certificat (doit correspondre à l'IP du serveur)
TLS_CN=192.168.100.251
HTTPS_PORT=9443

# --- Double interface réseau (production) ---
# Laisser commenté pour mode single-interface (dev / fallback).
# ADMIN_HOST  : IP interface réseau régie  (admin + AES67 + WebSocket)
# ADMIN_PORT  : port HTTPS admin (défaut = HTTPS_PORT)
# PUBLIC_HOST : IP interface WiFi public   (/, /hls uniquement, /admin bloqué)
# PUBLIC_PORT : port HTTPS public (défaut = HTTPS_PORT)
# PUBLIC_LISTENER_URL : URL communiquée aux spectateurs (QR code)
#ADMIN_HOST=192.168.100.251
#ADMIN_PORT=9443
#PUBLIC_HOST=10.0.0.1
#PUBLIC_PORT=9443
#PUBLIC_LISTENER_URL=https://10.0.0.1:9443

# --- Sécurité (OBLIGATOIRE: changer ces valeurs !) ---
ADMIN_PASSWORD=changeme
SESSION_SECRET=changeme-secret-key-min-32-chars

# --- URL publique (IP du serveur Docker sur votre réseau) ---
# C'est l'URL que verra le QR code affiché en salle
# En mode double interface, utiliser PUBLIC_LISTENER_URL à la place
PUBLIC_URL=https://192.168.100.251:9443

# --- Audio HLS ---
HLS_SEGMENT_DURATION=1
HLS_LIST_SIZE=3
AUDIO_SAMPLE_RATE=48000
AUDIO_BITRATE=128k

# --- AES67 / RTP multicast ---
# Tampon jitter réseau en ms (augmenter à 400-500 si vous avez des coupures)
RTP_BUFFER_MS=200
# Interface réseau pour rejoindre les groupes multicast
# Laisser vide pour auto-détection, ou spécifier l'IP de l'interface réseau
# vers votre réseau AES67 (ex: 192.168.1.100 ou eth0)
MULTICAST_INTERFACE=
